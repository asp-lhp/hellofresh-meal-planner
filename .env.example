# Meal Planner Environment Variables
# Copy this file to .env and fill in your values

# .NET API URL (default: http://localhost:5098/api)
# For deployment, set to your deployed API URL
API_BASE_URL=http://localhost:5098/api

# Database path (default: ../database/recipes.db relative to web/)
# For Fly.io deployment: /app/database/recipes.db
DATABASE_PATH=

# Anthropic API Key (required for AI features like recipe tagging)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Flask settings
FLASK_ENV=development
FLASK_DEBUG=1

# For production deployment:
# FLASK_ENV=production
# FLASK_DEBUG=0
# DATABASE_PATH=/app/database/recipes.db
# API_BASE_URL=https://meal-planner-api-asp.fly.dev/api
